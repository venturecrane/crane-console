# UI drift audit — copy-paste GitHub Actions workflow template.
#
# This is the per-venture CI gate for the enterprise design system. Each
# venture drops this file into `.github/workflows/ui-drift-audit.yml` and
# pairs it with a repo-root `.ui-drift.json` (see SKILL.md or the adoption
# runbook for the schema).
#
# What it does
#   1. On every PR that touches .tsx / .jsx / .css files (and on pushes to
#      main, for trend-line tracking), runs `audit.py --format json`.
#   2. Posts the audit summary as a sticky PR comment (creates / updates
#      one comment, no spam).
#   3. Fails the check if any of the three token-compliance metrics
#      (raw_hex_rgb_in_jsx, raw_hex_rgb_in_inline_style,
#      raw_tailwind_color_classes) exceed the limits in `.ui-drift.json`.
#      The threshold gate is the audit script's own non-zero exit code —
#      no separate jq comparison required here.
#
# Prerequisites in the consuming repo
#   - `.agents/skills/ui-drift-audit/audit.py` is present (synced via the
#     enterprise skill distribution mechanism, or vendored in by the
#     adoption-runbook checklist).
#   - `.ui-drift.json` is committed at the repo root with at least the
#     `thresholds` block. Without it, the audit reports counts but does
#     NOT gate (no thresholds = no breaches).
#   - Python >= 3.11 — the audit uses no third-party packages, so no
#     pip install step is needed.
#
# Customization knobs (per venture)
#   - `paths` filter: extend if your component layer lives outside
#     .tsx / .jsx / .css (e.g., add `**/*.astro` for SS).
#   - `--src` flag: override if your sources aren't in `src/pages` +
#     `src/components` (e.g., Next.js `app/`). Or set `src_dirs` in
#     `.ui-drift.json` and drop the flag here.
#   - `--status-words`: only set if you want to override the `.ui-drift.json`
#     value at workflow time (rare — usually leave blank).

name: ui-drift-audit

on:
  pull_request:
    paths:
      - "**/*.tsx"
      - "**/*.jsx"
      - "**/*.css"
      - ".ui-drift.json"
      - ".agents/skills/ui-drift-audit/**"
  push:
    branches: [main]

permissions:
  contents: read
  pull-requests: write

jobs:
  audit:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: ">=3.11"

      - name: Run UI drift audit
        id: audit
        run: |
          set +e
          STATUS_WORDS=""
          if [ -f .ui-drift.json ]; then
            STATUS_WORDS=$(jq -r '.status_words // [] | join(",")' .ui-drift.json)
          fi
          if [ -n "$STATUS_WORDS" ]; then
            python3 .agents/skills/ui-drift-audit/audit.py \
              --format json \
              --status-words "$STATUS_WORDS" \
              --out audit.json
          else
            python3 .agents/skills/ui-drift-audit/audit.py \
              --format json \
              --out audit.json
          fi
          echo "exit_code=$?" >> "$GITHUB_OUTPUT"

      - name: Build PR comment body
        if: github.event_name == 'pull_request'
        id: comment
        run: |
          python3 - <<'PY' > comment.md
          import json
          d = json.load(open("audit.json"))
          t = d["totals"]
          breaches = d.get("threshold_breaches", [])
          lines = []
          status = "FAIL" if breaches else "PASS"
          lines.append(f"### UI drift audit -- {status}")
          lines.append("")
          lines.append(f"- Files audited: {t['files']}")
          lines.append(f"- Raw hex/rgb in JSX: {t['raw_hex_rgb_in_jsx']}")
          lines.append(f"- Raw hex/rgb in inline style: {t['raw_hex_rgb_in_inline_style']}")
          lines.append(f"- Raw Tailwind color classes: {t['raw_tailwind_color_classes']}")
          lines.append(f"- Raw violation candidates: {t['raw_violations']}")
          if breaches:
            lines.append("")
            lines.append("**Threshold breaches**")
            for b in breaches:
              lines.append(f"- `{b['metric']}`: {b['actual']} > {b['max']}")
          else:
            lines.append("")
            lines.append("All thresholds passed.")
          lines.append("")
          lines.append("<sub>Generated by `ui-drift-audit` -- see `.ui-drift.json` to tune thresholds.</sub>")
          print("\n".join(lines))
          PY

      - name: Comment on PR
        if: github.event_name == 'pull_request'
        uses: marocchino/sticky-pull-request-comment@v2
        with:
          header: ui-drift-audit
          path: comment.md

      - name: Upload audit JSON
        uses: actions/upload-artifact@v4
        with:
          name: ui-drift-audit
          path: audit.json
          if-no-files-found: error

      - name: Enforce threshold gate
        if: steps.audit.outputs.exit_code != '0'
        run: |
          echo "ui-drift-audit threshold gate failed (audit.py exit_code=${{ steps.audit.outputs.exit_code }})"
          exit 1
