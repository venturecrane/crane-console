---
import { SignUp } from '@clerk/astro/components'
export const prerender = false
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Create account | Crane Command</title>
    <style>
      body {
        font-family: system-ui, sans-serif;
        background: #0b0b0b;
        color: #eaeaea;
        display: grid;
        place-items: center;
        min-height: 100vh;
        margin: 0;
      }
      main {
        width: 100%;
        max-width: 24rem;
        padding: 2rem;
      }
      h1 {
        font-size: 1.25rem;
        text-align: center;
        margin: 0 0 1.5rem;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Create your account</h1>
      <SignUp
        signInUrl="/auth/sign-in"
        fallbackRedirectUrl="/"
        forceRedirectUrl="/"
      />
    </main>
  </body>
</html>
