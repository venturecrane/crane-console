{
  "name": "venture-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "echo 'Configure your dev server'",
    "build": "tsc",
    "test": "vitest run --project unit --project harness",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run format:check && npm run lint && npm run test",
    "prepare": "node -e \"if(process.env.CI)process.exit(0)\" && husky"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260528.1",
    "@eslint/js": "^10.0.1",
    "@venturecrane/crane-test-harness": "^0.1.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "husky": "^9.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  }
}
