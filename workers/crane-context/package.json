{
  "name": "crane-context",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy",
    "deploy:prod": "wrangler deploy --env production",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --project unit --project harness",
    "test:canary": "vitest run --project canary",
    "test:legacy": "vitest run --project integration-legacy",
    "test:all": "vitest run",
    "db:migrate:apply": "bash ./scripts/check-d1-migrations.sh staging && wrangler d1 migrations apply crane-context-db-staging --remote",
    "db:migrate:apply:prod": "bash ./scripts/check-d1-migrations.sh production && wrangler d1 migrations apply crane-context-db-prod --remote --env production",
    "db:migrate:list": "wrangler d1 migrations list crane-context-db-staging --remote",
    "db:migrate:list:prod": "wrangler d1 migrations list crane-context-db-prod --remote --env production",
    "db:schema:bootstrap": "wrangler d1 execute crane-context-db-staging --remote --file=./migrations/schema.sql",
    "db:schema:bootstrap:prod": "wrangler d1 execute crane-context-db-prod --remote --file=./migrations/schema.sql --env production",
    "db:schema:bootstrap:local": "wrangler d1 execute crane-context-db-staging --local --file=./migrations/schema.sql",
    "db:migrate:check": "bash ./scripts/check-d1-migrations.sh"
  },
  "dependencies": {
    "@venturecrane/crane-contracts": "file:../../packages/crane-contracts",
    "canonicalize": "^2.0.0",
    "ulidx": "^2.3.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "@types/node": "^22.0.0",
    "@venturecrane/crane-test-harness": "file:../../packages/crane-test-harness",
    "esbuild": "^0.27.0",
    "json-schema-to-typescript": "^13.1.1",
    "miniflare": "^4.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.3",
    "wrangler": "^4.76.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
