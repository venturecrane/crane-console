{
  "name": "@venturecrane/eslint-config",
  "version": "0.1.0",
  "description": "Shared ESLint flat config for Venture Crane portfolio (TypeScript-on-Vercel/Cloudflare)",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "node -e \"console.log('eslint-config: no typecheck (pure JS)')\"",
    "test": "node -e \"console.log('eslint-config: no test yet')\""
  },
  "peerDependencies": {
    "eslint": ">=10.0.0",
    "typescript-eslint": ">=8.59.0"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "eslint-plugin-import-x": "^4.0.0",
    "globals": "^17.6.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "index.js",
    "README.md"
  ],
  "keywords": [
    "eslint",
    "eslint-config",
    "typescript",
    "venture-crane"
  ],
  "author": "Venture Crane",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/venturecrane/crane-console.git",
    "directory": "packages/eslint-config"
  }
}
