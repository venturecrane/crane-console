{
  "name": "@venturecrane/crane-test-harness",
  "version": "0.1.0",
  "description": "In-process HTTP test harness for Cloudflare Workers + D1 ventures",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./polyfills": {
      "types": "./dist/polyfills.d.ts",
      "import": "./dist/polyfills.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260507.1",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "files": [
    "dist",
    "D1_SEMANTIC_DIFFERENCES.md",
    "README.md"
  ],
  "keywords": [
    "test",
    "http",
    "cloudflare-workers",
    "d1",
    "sqlite",
    "venture-crane"
  ],
  "author": "Venture Crane",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/venturecrane/crane-console.git",
    "directory": "packages/crane-test-harness"
  }
}
